{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "InvokeThisAgentAlias",
      "Effect": "Allow",
      "Action": [
        "bedrock:InvokeAgent"
      ],
      "Resource": "arn:aws:bedrock:ap-southeast-2:123456789012:agent-alias/agent-abc123example/alias-abc123example"
    },
    {
      "Sid": "ReadAgentMetadataOptional",
      "Effect": "Allow",
      "Action": [
        "bedrock:GetAgent",
        "bedrock:GetAgentAlias",
        "bedrock:ListAgentAliases"
      ],
      "Resource": "*"
    }
  ]
}
